---
import MainLayout from '../layouts/MainLayout.astro';

const heroImages = [
  "/images/Daniel-y-Yo.jpg",
  "/images/20250130_121614.jpg",
  "/images/20240821_163941.jpg",
  "/images/20240824_125553-1.jpg",
  "/images/20241125_101126.jpg",
  "/images/20241229_150306.jpg",
  "/images/20240908_110742.jpg"
];

const metrics = [
  { value: "55+", label: "Años de Experiencia", icon: "🗺️" },
  { value: "2,500+", label: "Proyectos Entregados", icon: "📋" },
  { value: "15,000+", label: "Hectáreas Medidas", icon: "📐" },
  { value: "1,000+", label: "Clientes Satisfechos", icon: "👥" }
];

const services = [
  {
    title: "Topografía de Obras Civiles",
    description: "Levantamientos topográficos para construcción de carreteras, puentes, edificaciones e infraestructura vial.",
    image: "/images/Home7-2.jpg"
  },
  {
    title: "Planos Topográficos",
    description: "Elaboración de planos con curvas de nivel, puntos de control y detalles planimétricos precisos.",
    image: "/images/Home3-2.jpg"
  },
  {
    title: "Geodesia y GNSS",
    description: "Mediciones geodésicas de alta precisión utilizando tecnología GPS/GNSS de última generación.",
    image: "/images/20240821_163941.jpg"
  },
  {
    title: "Catastro y SIG",
    description: "Sistemas de Información Geográfica y gestión catastral para una mejor administración territorial.",
    image: "/images/20241125_101126.jpg"
  },
  {
    title: "Vuelo con Drones",
    description: "Levantamientos aéreos con drones para generación de modelos digitales de terreno y ortofotos.",
    image: "/images/20241229_150306.jpg"
  },
  {
    title: "Peritajes Topográficos",
    description: "Dictámenes periciales para juicios de propiedad, linderos y conflictos territoriales.",
    image: "/images/20240908_110742.jpg"
  }
];
---

<MainLayout title="Inicio">
  <!-- Hero con Slider -->
  <section class="relative h-[80vh] min-h-[600px] overflow-hidden">
    <div id="hero-slider" class="absolute inset-0">
      {heroImages.map((img, i) => (
        <div 
          class="absolute inset-0 transition-opacity duration-1000 ease-in-out"
          style={`opacity: ${i === 0 ? 1 : 0}`}
          data-slide={i}
        >
          <img 
            src={img} 
            alt={`Topografía Especializada ${i + 1}`}
            class="w-full h-full object-cover"
            loading={i === 0 ? "eager" : "lazy"}
          />
        </div>
      ))}
    </div>
    <div class="absolute inset-0 bg-black/75 z-[1]"></div>
    
    <div class="relative z-10 h-full flex items-center">
      <div class="container mx-auto px-4">
        <div class="max-w-3xl">
          <h1 class="text-4xl md:text-6xl font-bold text-white mb-6 leading-tight animate-fade-in">
            Expertos en <span class="text-primary">Topografía</span> desde 1970
          </h1>
          <p class="text-lg md:text-xl text-white/90 mb-8 max-w-2xl">
            Más de cinco décadas brindando servicios de topografía, geodesia y geomática con precisión, 
            compromiso y la más alta tecnología en David, Chiriquí y todo Panamá.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/services" class="btn btn-primary btn-lg">Nuestros Servicios</a>
            <a href="/contact" class="btn btn-outline btn-lg border-white text-white hover:bg-white hover:text-primary">Contáctenos</a>
          </div>
        </div>
      </div>
    </div>

    <!-- Slider indicators -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-20 flex gap-2">
      {heroImages.map((_, i) => (
        <button 
          class="w-3 h-3 rounded-full transition-all slider-dot"
          data-slide={i}
          aria-label={`Ir a imagen ${i + 1}`}
        />
      ))}
    </div>
  </section>

  <!-- Metrics Section -->
  <section class="py-16 bg-base-200">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {metrics.map(metric => (
          <div class="card bg-base-100 shadow-sm hover:shadow-lg transition-shadow">
            <div class="card-body items-center text-center py-8">
              <span class="text-4xl mb-2">{metric.icon}</span>
              <h2 class="card-title text-3xl font-bold text-primary">{metric.value}</h2>
              <p class="text-sm text-base-content/70">{metric.label}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services Preview con Imágenes -->
  <section class="py-20">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Servicios Profesionales</h2>
        <p class="text-base-content/70 max-w-2xl mx-auto">
          Ofrecemos soluciones integrales en topografía y geomática adaptadas a las necesidades de cada proyecto.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map(service => (
          <div class="card bg-base-100 border border-base-300 hover:border-primary hover:shadow-xl transition-all duration-300 overflow-hidden group">
            <figure class="h-48 overflow-hidden">
              <img 
                src={service.image} 
                alt={service.title}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                loading="lazy"
              />
            </figure>
            <div class="card-body">
              <h3 class="card-title text-xl">{service.title}</h3>
              <p class="text-base-content/70">{service.description}</p>
              <div class="card-actions justify-end mt-4">
                <a href="/services" class="btn btn-primary btn-sm">Más información</a>
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="text-center mt-10">
        <a href="/services" class="btn btn-outline btn-primary btn-lg">
          Ver Todos los Servicios
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- About Preview -->
  <section class="py-20 bg-base-200">
    <div class="container mx-auto px-4">
      <div class="flex flex-col lg:flex-row items-center gap-12">
        <div class="flex-1">
          <div class="badge badge-primary badge-outline mb-4">Sobre Nosotros</div>
          <h2 class="text-3xl md:text-4xl font-bold mb-6">
            Tres Generaciones de <span class="text-primary">Experiencia y Compromiso</span>
          </h2>
          <p class="text-base-content/70 mb-6">
            Fundada en 1970 por el Ing. Ricardo A. Sanjur S., Topografía Especializada S.A. ha crecido 
            de la mano de su familia, manteniendo los valores de precisión, honestidad y servicio al cliente 
            que nos han caracterizado por más de 55 años.
          </p>
          <ul class="space-y-3 mb-8">
            <li class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-full bg-primary/20 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </div>
              <span>Equipo multidisciplinario de profesionales</span>
            </li>
            <li class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-full bg-primary/20 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </div>
              <span>Equipamiento de última generación</span>
            </li>
            <li class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-full bg-primary/20 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-primary" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </div>
              <span>Compromiso con la precisión y puntualidad</span>
            </li>
          </ul>
          <a href="/about" class="btn btn-primary">Conocer Más</a>
        </div>
        <div class="flex-1">
          <div class="card bg-base-100 shadow-xl overflow-hidden rounded-2xl">
            <figure class="h-64 bg-white m-4">
              <img src="/images/rs-topo-3.png" alt="Ricardo Sanjur" class="w-full h-full object-contain rounded-xl" loading="lazy" />
            </figure>
            <div class="card-body">
              <h3 class="card-title text-2xl mb-4">¿Por qué elegirnos?</h3>
              <div class="space-y-4">
                <div class="flex items-start gap-4">
                  <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center flex-shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                    </svg>
                  </div>
                  <div>
                    <h4 class="font-semibold">Garantía de Precisión</h4>
                    <p class="text-sm text-base-content/70">Mediciones verificadas y certificadas</p>
                  </div>
                </div>
                <div class="flex items-start gap-4">
                  <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center flex-shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                  </div>
                  <div>
                    <h4 class="font-semibold">Puntualidad</h4>
                    <p class="text-sm text-base-content/70">Entrega en los plazos acordados</p>
                  </div>
                </div>
                <div class="flex items-start gap-4">
                  <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center flex-shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z" />
                    </svg>
                  </div>
                  <div>
                    <h4 class="font-semibold">Atención Personalizada</h4>
                    <p class="text-sm text-base-content/70">Asesoría directa con nuestros expertos</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 bg-primary text-primary-content">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">¿Necesita una cotización?</h2>
      <p class="text-primary-content/80 max-w-2xl mx-auto mb-8">
        Contáctenos hoy mismo y recibirá una evaluación personalizada de su proyecto sin compromiso.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/services" class="btn btn-secondary btn-lg">Solicitar Cotización</a>
        <a href="tel:+50766714646" class="btn btn-outline btn-lg border-primary-content text-primary-content hover:bg-primary-content hover:text-primary">
          Llamar: +507 6671-4646
        </a>
      </div>
    </div>
  </section>
</MainLayout>

<script>
  // Preload images
  const heroImages = [
    "/images/Daniel-y-Yo.jpg",
    "/images/20250130_121614.jpg",
    "/images/20240821_163941.jpg",
    "/images/20240824_125553-1.jpg",
    "/images/20241125_101126.jpg",
    "/images/20241229_150306.jpg",
    "/images/20240908_110742.jpg"
  ];
  
  heroImages.forEach(src => {
    const img = new Image();
    img.src = src;
  });

  const slides = document.querySelectorAll('#hero-slider > div[data-slide]');
  const dots = document.querySelectorAll('.slider-dot');
  let currentSlide = 0;

  function showSlide(index: number) {
    const total = slides.length;
    const normalizedIndex = ((index % total) + total) % total;
    
    slides.forEach((slide, i) => {
      (slide as HTMLElement).style.opacity = i === normalizedIndex ? '1' : '0';
    });
    
    dots.forEach((dot, i) => {
      dot.classList.toggle('bg-white', i === normalizedIndex);
      dot.classList.toggle('bg-white/50', i !== normalizedIndex);
      dot.classList.toggle('scale-125', i === normalizedIndex);
    });
    currentSlide = normalizedIndex;
  }

  dots.forEach((dot, i) => {
    dot.classList.add('bg-white/50');
    dot.addEventListener('click', () => showSlide(i));
  });

  showSlide(0);

  setInterval(() => {
    showSlide(currentSlide + 1);
  }, 5000);
</script>
<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fadeIn 1s ease-out;
  }
</style>
